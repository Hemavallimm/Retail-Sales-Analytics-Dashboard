# Create Database
CREATE DATABASE IF NOT EXISTS PBI_DB;

# Create Schema
CREATE SCHEMA IF NOT EXISTS PBI_DB.SALES_SCHEMA;

# create Tables
CREATE OR REPLACE TABLE PBI_DB.SALES_SCHEMA.SALES_DATA (
    SALES_DATE DATE,
    PRODUCT STRING,
    CATEGORY STRING,
    QUANTITY NUMBER,
    SALES NUMBER(12,2),
    COST NUMBER(12,2),
    REGION STRING,
    CUSTOMER STRING
);

# Create file format
CREATE OR REPLACE FILE FORMAT PBI_DB.SALES_SCHEMA.CSV_FORMAT
TYPE = 'CSV'
SKIP_HEADER = 1
FIELD_OPTIONALLY_ENCLOSED_BY = '"'
DATE_FORMAT = 'YYYY-MM-DD HH24:MI:SS';

# Create Stage (Storage location)
CREATE OR REPLACE STAGE PBI_DB.SALES_SCHEMA.PBI_STAGE
FILE_FORMAT = CSV_FORMAT;

# Upload CSV file
Option 1: Snowflake UI
Open PBI_STAGE
Upload PowerBI_Practice_Dataset.csv

Option 2: SQL (if using SnowSQL)
PUT file://PowerBI_Practice_Dataset.csv @PBI_DB.SALES_SCHEMA.PBI_STAGE;

# Load Data into Table
COPY INTO PBI_DB.SALES_SCHEMA.SALES_DATA
FROM @PBI_DB.SALES_SCHEMA.PBI_STAGE;

# Validate Load
SELECT COUNT(*) FROM PBI_DB.SALES_SCHEMA.SALES_DATA;
SELECT * FROM PBI_DB.SALES_SCHEMA.SALES_DATA LIMIT 10;

# Create Business logic
CREATE OR REPLACE VIEW PBI_DB.SALES_SCHEMA.VW_SALES_ANALYTICS AS
SELECT
    SALES_DATE,
    PRODUCT,
    CATEGORY,
    REGION,
    CUSTOMER,
    QUANTITY,
    SALES,
    COST,
    SALES - COST AS PROFIT,
    ROUND((SALES - COST) / SALES * 100, 2) AS PROFIT_MARGIN
FROM PBI_DB.SALES_SCHEMA.SALES_DATA;
